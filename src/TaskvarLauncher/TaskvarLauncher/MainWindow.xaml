<Window x:Class="TaskbarLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="StackBar - 設定"
        Height="800"
        Width="1200"
        MinHeight="800"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- サイドバー -->
        <Grid Grid.Column="0" Background="#17172A">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- グループ一覧エリア（後で実装） -->
            <!-- グループ一覧 -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="48"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                     ItemsSource="{Binding Groups}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#FFFFFF">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" 
                           FontSize="14"
                           Padding="8,6"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 新規グループ追加ボタン -->
                <Button Grid.Row="1"
            Content="＋ 新規グループ"
            Background="Transparent"
            Foreground="#888888"
            BorderThickness="0"
            FontSize="13"
            Cursor="Hand"
            Click="AddGroup_Click"/>
            </Grid>

            <!-- 歯車ボタン -->
            <Button Grid.Row="1"
                    Content="設定"
                    Background="Transparent"
                    Foreground="#888888"
                    BorderThickness="0"
                    FontSize="14"
                    Cursor="Hand"/>
        </Grid>

        <!-- メインコンテンツ -->
        <Border Grid.Column="1" Padding="24">
            <TextBlock Text="グループを選択してください" 
                       Foreground="#888888"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>